            <Font size="16.0" />
         </font>
      </Label>
      
      <Button mnemonicParsing="false" onAction="#handleProbarBoton" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-padding: 10 20; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Probar Conexión" />
