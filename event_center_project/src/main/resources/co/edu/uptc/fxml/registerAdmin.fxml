<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="fondo-pantalla-Interior"
            stylesheets="@../css/styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.uptc.viewController.AnadirAdminController">

    <top>
        <HBox alignment="CENTER_LEFT"
              prefHeight="65.0"
              styleClass="fondo-pantalla-Interior">
            <padding>
                <Insets top="10.0"
                        right="10.0"
                        bottom="10.0"
                        left="16.0" />
            </padding>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER"
              VBox.vgrow="ALWAYS"
              BorderPane.alignment="CENTER">

            <padding>
                <Insets top="20.0"
                        right="60.0"
                        bottom="20.0"
                        left="60.0" />
            </padding>

            <children>

                <Label text="Crear administrador"
                       styleClass="titulo-seccion" />

                <VBox spacing="16.0"
                      alignment="CENTER_LEFT"
                      styleClass="formulario-contenedor"
                      VBox.vgrow="ALWAYS">

                    <children>

                        <HBox spacing="16.0" alignment="CENTER_LEFT">
                            <Label minWidth="200.0"
                                   styleClass="titulo-seccion"
                                   text="Cédula:" />
                            <TextField fx:id="txtId"
                                       promptText="Ingrese cédula"
                                       styleClass="campo-texto" />
                        </HBox>

                        <HBox spacing="16.0" alignment="CENTER_LEFT">
                            <Label minWidth="200.0"
                                   styleClass="titulo-seccion"
                                   text="%admin.services.mostrar.nombre" />
                            <TextField fx:id="txtNombre"
                                       promptText="Ingrese nombre"
                                       styleClass="campo-texto" />
                        </HBox>

                        <HBox spacing="16.0" alignment="CENTER_LEFT">
                            <Label minWidth="200.0"
                                   styleClass="titulo-seccion"
                                   text="Correo:" />
                            <TextField fx:id="txtCorreo"
                                       promptText="Ingrese correo"
                                       styleClass="campo-texto" />
                        </HBox>

                        <HBox spacing="16.0" alignment="CENTER_LEFT">
                            <Label minWidth="200.0"
                                   styleClass="titulo-seccion"
                                   text="Teléfono:" />
                            <TextField fx:id="txtTelefono"
                                       promptText="Ingrese teléfono"
                                       styleClass="campo-texto" />
                        </HBox>

                        <HBox spacing="16.0" alignment="CENTER_LEFT">
                            <Label minWidth="200.0"
                                   styleClass="titulo-seccion"
                                   text="Contraseña:" />
                            <TextField fx:id="txtPassword"
                                       promptText="Ingrese contraseña"
                                       styleClass="campo-texto" />
                        </HBox>

                    </children>

                </VBox>

                <HBox spacing="12.0"
                      alignment="CENTER_RIGHT"
                      styleClass="barra-acciones">

                    <children>

                        <Button fx:id="btnCancelar"
                                text="Cancelar"
                                styleClass="btn-accion"
                                prefHeight="65.0"
                                prefWidth="240.0"
                                onAction="#cancelar" />

                        <Button fx:id="btnGuardar"
                                text="Guardar"
                                styleClass="btn-portal"
                                prefHeight="65.0"
                                prefWidth="240.0"
                                onAction="#guardarAdmin" />

                    </children>

                </HBox>

            </children>

        </VBox>
    </center>

    <padding>
        <Insets top="8.0"
                right="8.0"
                bottom="8.0"
                left="8.0" />
    </padding>

</BorderPane>
