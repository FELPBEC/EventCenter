<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="fondo-pantalla-Interior"
            stylesheets="@../css/styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.uptc.viewController.PerfilAdminController">

   <!-- BARRA INFERIOR reutilizable -->
   <bottom>
      <fx:include source="bottomBar.fxml" />
   </bottom>

   <!-- MENU LATERAL reutilizable -->
   <left>
      <fx:include fx:id="sideMenuContainer" source="sideBar.fxml" />
   </left>

   <!-- BOTON HOME toggle del menu -->
   <top>
   <HBox alignment="CENTER_LEFT"
         prefHeight="65.0"
         styleClass="fondo-pantalla-Interior">
      <padding>
         <Insets top="10.0" right="10.0" bottom="10.0" left="16.0" />
      </padding>
      <children>
         <Button fx:id="btnToggleMenu"
                 styleClass="btn-portal"
                 onAction="#toggleMenu"
                 prefHeight="50.0"
                 prefWidth="60.0">
            <graphic>
               <ImageView fitHeight="32.0" fitWidth="32.0"
                          pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@/co/edu/uptc/images/IconoMenú.png" />
                  </image>
               </ImageView>
            </graphic>
         </Button>
      </children>
   </HBox>
   </top>

   <!-- CONTENIDO CENTRAL: tarjeta de perfil -->
   <center>
      <VBox alignment="CENTER"
            VBox.vgrow="ALWAYS"
            BorderPane.alignment="CENTER">
         <padding>
            <Insets top="20.0" right="60.0" bottom="20.0" left="60.0" />
         </padding>
         <children>

            <!-- TARJETA principal -->
            <HBox styleClass="capa-informacion"
                  VBox.vgrow="ALWAYS">

               <!-- Franja izquierda con avatar -->
               <VBox alignment="CENTER"
                     styleClass="franja-perfil"
                     prefWidth="220.0"
                     minWidth="180.0"
                     maxWidth="260.0"
                     HBox.hgrow="NEVER">
                  <children>
                     <ImageView fx:id="imgAvatar"
                                fitHeight="220.0"
                                fitWidth="220.0"
                                pickOnBounds="true"
                                preserveRatio="true">
                        <image>
                           <Image url="@/co/edu/uptc/images/AdminsLogo.png" />
                        </image>
                     </ImageView>
                  </children>
               </VBox>

               <!-- Datos del perfil -->
               <VBox alignment="CENTER_LEFT"
                     spacing="28.0"
                     HBox.hgrow="ALWAYS">
                  <padding>
                     <Insets top="40.0" right="60.0" bottom="20.0" left="50.0" />
                  </padding>
                  <children>

                     <!-- Titulo -->
                     <Label text="%perfil.titulo"
                            styleClass="titulo-principal">
                        <VBox.margin>
                           <Insets bottom="10.0" />
                        </VBox.margin>
                     </Label>

                     <!-- Nombre -->
                     <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <children>
                           <Label text="%perfil.nombre"
                                  styleClass="titulo-seccion"
                                  minWidth="180.0" />
                           <Label fx:id="lblNombre"
                                  styleClass="label-valor" />
                        </children>
                     </HBox>

                     <!-- Cedula -->
                     <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <children>
                           <Label text="%perfil.cedula"
                                  styleClass="titulo-seccion"
                                  minWidth="180.0" />
                           <Label fx:id="lblCedula"
                                  styleClass="label-valor" />
                        </children>
                     </HBox>

                     <!-- Telefono -->
                     <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <children>
                           <Label text="%perfil.telefono"
                                  styleClass="titulo-seccion"
                                  minWidth="180.0" />
                           <Label fx:id="lblTelefono"
                                  styleClass="label-valor" />
                        </children>
                     </HBox>

                     <!-- Correo -->
                     <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <children>
                           <Label text="%perfil.correo"
                                  styleClass="titulo-seccion"
                                  minWidth="180.0" />
                           <Label fx:id="lblCorreo"
                                  styleClass="label-valor" />
                        </children>
                     </HBox>

                  </children>
               </VBox>

            </HBox>

            <!-- BARRA DE ACCIONES -->
            <HBox styleClass="barra-acciones"
                  minHeight="90.0"
                  maxHeight="90.0">
               <children>
                  <Button fx:id="btnCambiarPassword"
                        text="%perfil.btn.cambiarPassword"
                        styleClass="btn-accion"
                        onAction="#cambiarPassword"
                        prefHeight="65.0"
                        prefWidth="320.0" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnModificarPerfil"
                        text="%perfil.btn.modificar"
                        styleClass="btn-accion"
                        onAction="#modificarPerfil"
                        prefHeight="65.0"
                        prefWidth="280.0" />
               </children>
            </HBox>
         </children>
      </VBox>
   </center>

</BorderPane>