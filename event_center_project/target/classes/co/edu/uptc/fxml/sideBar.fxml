<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox maxWidth="360.0" minWidth="360.0" prefWidth="360.0" style="-fx-border-color: black; -fx-border-width: 3; -fx-border-radius: 10; -fx-background-radius: 10;" styleClass="fondo-pantalla-Interior" VBox.vgrow="NEVER" stylesheets="@../css/styles.css"  xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uptc.viewController.SideMenuController">

   <children>

      <!-- CABECERA: avatar + boton editar perfil -->
      <HBox alignment="CENTER_LEFT" maxHeight="130.0" minHeight="130.0" prefHeight="130.0" spacing="10.0" styleClass="capa-informacion">
         <padding>
            <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
         </padding>
         <children>
            <ImageView fx:id="imgAvatar" fitHeight="88.0" fitWidth="80.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@/co/edu/uptc/images/AdminsLogo.png" />
               </image>
            </ImageView>
            <Button fx:id="btnEditarPerfil" maxWidth="1.7976931348623157E308" onAction="#irAEditarPerfil" prefHeight="91.0" styleClass="btn-portal" text="%menu.editarPerfil" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>

      <!-- BOTONES DE NAVEGACION -->
      <VBox alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="24.0" left="14.0" right="14.0" top="24.0" />
         </padding>
         <children>
            <Button fx:id="btnClientes" maxWidth="1.7976931348623157E308" onAction="#irAClientes" prefHeight="85.0" styleClass="btn-portal" text="%menu.clientes" />
            <Button fx:id="btnSalones" maxWidth="1.7976931348623157E308" onAction="#irASalones" prefHeight="85.0" styleClass="btn-portal" text="%menu.salones" />
            <Button fx:id="btnAdmins" maxWidth="1.7976931348623157E308" onAction="#irAAdmins" prefHeight="85.0" styleClass="btn-portal" text="%menu.admins" />
            <Button fx:id="btnReportes" maxWidth="1.7976931348623157E308" onAction="#irAReportes" prefHeight="85.0" styleClass="btn-portal" text="%menu.reportes" />
         </children>
      </VBox>

      <!-- ESPACIADOR -->
      <Region VBox.vgrow="ALWAYS" />

      <!-- PIE: icono + boton cerrar sesion -->
      <StackPane maxHeight="90.0" minHeight="90.0" prefHeight="90.0" styleClass="barra-inferior">
         <children>
            <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true" StackPane.alignment="CENTER_LEFT">
               <StackPane.margin>
                  <Insets left="14.0" />
               </StackPane.margin>
               <image>
                  <Image url="@/co/edu/uptc/images/IconoSalir.png" />
               </image>
            </ImageView>
            <Button fx:id="btnCerrarSesion" onAction="#cerrarSesion" prefHeight="62.0" prefWidth="240.0" styleClass="btn-portal" text="%menu.cerrarSesion" StackPane.alignment="CENTER_RIGHT">
               <StackPane.margin>
                  <Insets right="14.0" />
               </StackPane.margin>
            </Button>
         </children>
      </StackPane>

   </children>
</VBox>
